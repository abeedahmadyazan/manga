rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return request.auth.token.email;
    }

    function isAdmin() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Helper: the request is for the currently signed-in user's own document
    function isOwnUserDoc(email) {
      return isSignedIn() && userEmail() == email;
    }

    // Helper: the requester owns the resource (by authorEmail field)
    function isAuthor() {
      return isSignedIn() &&
             resource.data.authorEmail == userEmail();
    }

    match /admins/{uid} {
      allow read, list: if isSignedIn();
      // ONLY Admin SDK (server) can create admin docs — never the app.
      allow create: if false;
      allow update, delete: if isAdmin();
    }

    match /user_uids/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    match /users/{email} {
      allow read: if isSignedIn();
      // User can only create their OWN user doc (matching their auth email).
      allow create: if isOwnUserDoc(email);
      // FIX: user can update ONLY their own doc — not anyone else's.
      allow update: if isOwnUserDoc(email);
      // Only admin can delete user accounts.
      allow delete: if isAdmin();
    }

    match /comments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.text is string
                    && request.resource.data.text.size() >= 1
                    && request.resource.data.text.size() <= 500
                    && request.resource.data.authorEmail == userEmail()
                    && request.resource.data.contextId is string
                    && request.resource.data.contextId.size() <= 200
                    && request.resource.data.createdAt is number
                    && request.resource.data.createdAt <= request.time.toMillis() + 5000;
      // FIX: only the author can edit their own comment.
      allow update: if isAuthor()
                    && request.resource.data.text is string
                    && request.resource.data.text.size() >= 1
                    && request.resource.data.text.size() <= 500
                    // authorEmail cannot be changed during update (prevents hijacking)
                    && request.resource.data.authorEmail == resource.data.authorEmail;
      // Author or admin can delete.
      allow delete: if isAuthor() || isAdmin();
    }

    match /replies/{replyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.text is string
                    && request.resource.data.text.size() >= 1
                    && request.resource.data.text.size() <= 500
                    && request.resource.data.authorEmail == userEmail()
                    && request.resource.data.parentId is string
                    && request.resource.data.createdAt is number
                    && request.resource.data.createdAt <= request.time.toMillis() + 5000;
      allow update: if isAuthor()
                    && request.resource.data.text is string
                    && request.resource.data.text.size() <= 500
                    && request.resource.data.authorEmail == resource.data.authorEmail;
      allow delete: if isAuthor() || isAdmin();
    }

    // FIX: cooldowns can only be READ by the user, never written from the
    // app. Only the server (Admin SDK) sets cooldowns — prevents users from
    // clearing their own cooldown to spam comments.
    match /comment_cooldowns/{email} {
      allow read: if isSignedIn() && userEmail() == email;
      allow write: if false;
    }

    match /banned_users/{email} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ============================================================
    //  login_blocks — Brute Force protection
    //  Field name: `until` (timestamp ms when block expires)
    //  Principle: block can be created and EXTENDED, never deleted or shortened.
    //  This prevents an attacker from lifting their own block.
    //  Read is open (the app checks the block before login, when auth may be null).
    // ============================================================
    match /login_blocks/{deviceId} {
      allow read: if true;
      allow create: if request.resource.data.until is int
                    && request.resource.data.until > 0;
      allow update: if request.resource.data.until is int
                    && request.resource.data.until > resource.data.until;
      allow delete: if false;
    }

    // ============================================================
    //  login_attempts — Failed login counter
    //  Field names: `count` (int), `lastAttempt` (timestamp ms)
    //  Principle: counter can only INCREASE, or reset to 1 after the 30-min
    //  window has passed (measured by lastAttempt). An attacker cannot
    //  zero their own counter, and cannot reset it before the window expires.
    // ============================================================
    match /login_attempts/{deviceId} {
      allow read: if true;
      allow create: if request.resource.data.count is int
                    && request.resource.data.count == 1
                    && request.resource.data.lastAttempt is int
                    && request.resource.data.lastAttempt <= request.time.toMillis() + 5000;
      allow update: if request.resource.data.count is int
                    && request.resource.data.lastAttempt is int
                    && request.resource.data.lastAttempt <= request.time.toMillis() + 5000
                    && request.resource.data.lastAttempt >= resource.data.lastAttempt
                    && (
                      // Case A: normal increment — count must strictly increase
                      request.resource.data.count > resource.data.count
                      ||
                      // Case B: window expired (30 min) — allow reset to 1
                      // (request.time - lastAttempt > 30 minutes in ms)
                      (request.time.toMillis() - resource.data.lastAttempt > 1800000
                       && request.resource.data.count == 1)
                    );
      allow delete: if false;
    }

    // FIX: user lists are private to the owner. Only the user themselves
    // (matching their auth email) can read or modify their lists.
    match /user_lists/{email} {
      allow read: if isOwnUserDoc(email);
      allow create: if isOwnUserDoc(email);
      allow update: if isOwnUserDoc(email);
      allow delete: if isOwnUserDoc(email) || isAdmin();
    }

    // FIX: reading history is private to the owner.
    match /reading_history/{email} {
      allow read: if isOwnUserDoc(email);
      allow create: if isOwnUserDoc(email);
      allow update: if isOwnUserDoc(email);
      allow delete: if isOwnUserDoc(email) || isAdmin();
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn()
                    && request.resource.data.reason is string
                    && request.resource.data.reason.size() <= 200
                    && request.resource.data.reportedBy == userEmail();
      allow update, delete: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // Catch-all: deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
