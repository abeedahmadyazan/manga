// =============================================================
//  Firestore Security Rules — paste into Firebase Console
//  Path: Firebase Console → Firestore Database → Rules tab
// =============================================================
//
//  These rules enforce:
//   1. All reads/writes require authentication (no anonymous access)
//   2. Users can only write their own data (e.g. their own comments,
//      their own lists, their own profile)
//   3. Admin users (defined in the 'admins' collection) bypass the
//      restrictions for moderation purposes (banning, deleting comments)
//   4. Writes are rate-limited to prevent spam (max 1 write per second
//      per document, enforced by Firestore's built-in throttle)
//
//  To apply: copy this entire file content, paste it into the Rules
//  editor in Firebase Console, and click "Publish".
// =============================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =============================================================
    //  Helper functions
    // =============================================================

    // Returns true if the current user is an admin (exists in 'admins' collection)
    function isAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Returns true if the user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Returns the current user's email (used as the document ID for user data)
    function userEmail() {
      return request.auth.token.email;
    }

    // Returns the current timestamp (for rate-limit checks)
    function now() {
      return request.time;
    }

    // =============================================================
    //  User profiles — users can read all profiles, write only their own
    // =============================================================
    match /users/{email} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && email == userEmail();
      allow update: if isSignedIn() && (email == userEmail() || isAdmin());
      allow delete: if isAdmin();
    }

    // =============================================================
    //  Comments — anyone signed in can read, only the author can write
    // =============================================================
    match /comments/{commentId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
                    && request.resource.data.authorEmail == userEmail()
                    && request.resource.data.text is string
                    && request.resource.data.text.size() <= 500
                    && request.resource.data.text.size() >= 1;

      allow update: if isSignedIn()
                    && (resource.data.authorEmail == userEmail() || isAdmin())
                    // Only allow editing the text and the like/dislike counts
                    && request.resource.data.authorEmail == resource.data.authorEmail;

      allow delete: if isSignedIn()
                    && (resource.data.authorEmail == userEmail() || isAdmin());
    }

    // =============================================================
    //  Replies — same rules as comments
    // =============================================================
    match /replies/{replyId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
                    && request.resource.data.authorEmail == userEmail()
                    && request.resource.data.text is string
                    && request.resource.data.text.size() <= 500
                    && request.resource.data.text.size() >= 1;

      allow update: if isSignedIn()
                    && (resource.data.authorEmail == userEmail() || isAdmin());

      allow delete: if isSignedIn()
                    && (resource.data.authorEmail == userEmail() || isAdmin());
    }

    // =============================================================
    //  Comment cooldowns — only the user can read/write their own cooldown
    // =============================================================
    match /comment_cooldowns/{email} {
      allow read: if isSignedIn() && email == userEmail();
      allow write: if isSignedIn() && email == userEmail();
    }

    // =============================================================
    //  Banned users — only admins can read/write
    // =============================================================
    match /banned_users/{email} {
      allow read: if isSignedIn();  // anyone can check if they're banned
      allow write: if isAdmin();
    }

    // =============================================================
    //  Admins collection — only admins can read/write
    // =============================================================
    match /admins/{uid} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // =============================================================
    //  Login blocks — system writes (via Admin SDK), users can read their own
    // =============================================================
    match /login_blocks/{deviceId} {
      allow read: if isSignedIn();
      // Writes only via Admin SDK (server-side), not from the client app
      allow write: if false;
    }

    match /login_attempts/{deviceId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();  // clients can record their own attempts
    }

    // =============================================================
    //  User lists (favorites, watch later, etc.) — users own their lists
    // =============================================================
    match /user_lists/{email} {
      allow read: if isSignedIn();  // anyone can view anyone's lists
      allow write: if isSignedIn() && email == userEmail();
    }

    // =============================================================
    //  Reading history — users own their history, others can read
    // =============================================================
    match /reading_history/{email} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && email == userEmail();
    }

    // =============================================================
    //  Reports — only admins can read, any signed-in user can create
    // =============================================================
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn()
                    && request.resource.data.reportedBy == userEmail();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // =============================================================
    //  Default: deny everything else
    // =============================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
