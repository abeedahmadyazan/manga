rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /admins/{uid} {
      allow read, list: if isSignedIn();
      // ONLY Admin SDK (server) can create admin docs — NOT the app!
      allow create: if false;
      allow update, delete: if isAdmin();
    }

    match /user_uids/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    match /users/{email} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /comments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.text is string
                    && request.resource.data.text.size() >= 1
                    && request.resource.data.text.size() <= 500;
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /replies/{replyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.text is string
                    && request.resource.data.text.size() >= 1
                    && request.resource.data.text.size() <= 500;
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /comment_cooldowns/{email} {
      allow read, write: if isSignedIn();
    }

    match /banned_users/{email} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /login_blocks/{deviceId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /login_attempts/{deviceId} {
      allow read, write: if isSignedIn();
    }

    match /user_lists/{email} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /reading_history/{email} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
