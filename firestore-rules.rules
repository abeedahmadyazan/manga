rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return request.auth.token.email;
    }

    function isAdmin() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /admins/{uid} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn()
                    && request.auth.uid == uid
                    && request.resource.data.role == "admin";
      allow update, delete: if isAdmin();
    }

    match /user_uids/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    // === FIXED: allow any signed-in user (anonymous included) ===
    match /users/{email} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /comments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.text is string
                    && request.resource.data.text.size() >= 1
                    && request.resource.data.text.size() <= 500
                    && request.resource.data.authorEmail == userEmail()
                    && request.resource.data.contextId is string
                    && request.resource.data.contextId.size() <= 200
                    && request.resource.data.createdAt is number
                    && request.resource.data.createdAt <= request.time.toMillis() + 5000;
      allow update: if isSignedIn()
                    && resource.data.authorEmail == userEmail()
                    && request.resource.data.text is string
                    && request.resource.data.text.size() >= 1
                    && request.resource.data.text.size() <= 500;
      allow delete: if isSignedIn()
                    && (resource.data.authorEmail == userEmail() || isAdmin());
    }

    match /replies/{replyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.text is string
                    && request.resource.data.text.size() >= 1
                    && request.resource.data.text.size() <= 500
                    && request.resource.data.authorEmail == userEmail()
                    && request.resource.data.parentId is string
                    && request.resource.data.createdAt is number
                    && request.resource.data.createdAt <= request.time.toMillis() + 5000;
      allow update: if isSignedIn()
                    && resource.data.authorEmail == userEmail()
                    && request.resource.data.text is string
                    && request.resource.data.text.size() <= 500;
      allow delete: if isSignedIn()
                    && (resource.data.authorEmail == userEmail() || isAdmin());
    }

    match /comment_cooldowns/{email} {
      allow read, write: if isSignedIn();
    }

    match /banned_users/{email} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /login_blocks/{deviceId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /login_attempts/{deviceId} {
      allow read, write: if isSignedIn();
    }

    match /user_lists/{email} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /reading_history/{email} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn()
                    && request.resource.data.reason is string
                    && request.resource.data.reason.size() <= 200
                    && request.resource.data.reportedBy == userEmail();
      allow update, delete: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
