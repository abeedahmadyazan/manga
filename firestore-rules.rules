rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =============================================================
    //  Helper functions
    // =============================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return request.auth.token.email;
    }

    function isAdmin() {
      // Check if user's UID exists in the 'admins' collection.
      // The app auto-creates this document on first sign-in (bootstrap).
      return isSignedIn() &&
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // =============================================================
    //  ADMINS collection — anyone signed in can read
    // =============================================================
    match /admins/{uid} {
      allow read, list: if isSignedIn();
      // STRICT: only existing admins can create/update/delete admin docs.
      // This prevents any user from self-promoting.
      // The first admin doc must be created manually in Firebase Console
      // (one-time setup). After that, only admins can add new admins.
      allow create, update, delete: if isAdmin();
    }

    // =============================================================
    //  UID → Email index (for restoring profile after reinstall)
    // =============================================================
    match /user_uids/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    // =============================================================
    //  User profiles
    // =============================================================
    match /users/{email} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // =============================================================
    //  Comments — permissive (client enforces cooldowns)
    // =============================================================
    match /comments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.text is string
                    && request.resource.data.text.size() >= 1
                    && request.resource.data.text.size() <= 500;
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // =============================================================
    //  Replies
    // =============================================================
    match /replies/{replyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.text is string
                    && request.resource.data.text.size() >= 1
                    && request.resource.data.text.size() <= 500;
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // =============================================================
    //  Comment cooldowns
    // =============================================================
    match /comment_cooldowns/{email} {
      allow read, write: if isSignedIn();
    }

    // =============================================================
    //  Banned users
    // =============================================================
    match /banned_users/{email} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // =============================================================
    //  Login blocks / attempts
    // =============================================================
    match /login_blocks/{deviceId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /login_attempts/{deviceId} {
      allow read, write: if isSignedIn();
    }

    // =============================================================
    //  User lists
    // =============================================================
    match /user_lists/{email} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // =============================================================
    //  Reading history
    // =============================================================
    match /reading_history/{email} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // =============================================================
    //  Reports
    // =============================================================
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // =============================================================
    //  Default: deny everything else
    // =============================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
