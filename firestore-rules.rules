rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =============================================================
    //  Helper functions
    // =============================================================

    // Returns true if the current user is an admin.
    // An admin is any user whose UID exists as a document in the 'admins'
    // collection. To make a user an admin, create a document at
    // /admins/{theirUID} with fields: email, role="admin".
    function isAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Returns true if the user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Returns the current user's email
    function userEmail() {
      return request.auth.token.email;
    }

    // =============================================================
    //  ADMINS collection — only admins can read/write this.
    //  To become an admin, a user's UID must be added here.
    // =============================================================
    match /admins/{uid} {
      // Allow a user to READ their own admin document (so the app can check
      // if they're an admin). Admins can read all admin docs.
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      // Only existing admins can create/update/delete admin docs
      // (prevents privilege escalation: a regular user can't make themselves admin)
      allow create, update, delete: if isAdmin();
    }

    // =============================================================
    //  User profiles — users can read all, write only their own
    // =============================================================
    match /users/{email} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && email == userEmail();
      allow update: if isSignedIn() && (email == userEmail() || isAdmin());
      allow delete: if isAdmin();
    }

    // =============================================================
    //  Comments
    // =============================================================
    match /comments/{commentId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
                    && request.resource.data.authorEmail == userEmail()
                    && request.resource.data.text is string
                    && request.resource.data.text.size() <= 500
                    && request.resource.data.text.size() >= 1;

      allow update: if isSignedIn()
                    && (resource.data.authorEmail == userEmail() || isAdmin())
                    && request.resource.data.authorEmail == resource.data.authorEmail;

      allow delete: if isSignedIn()
                    && (resource.data.authorEmail == userEmail() || isAdmin());
    }

    // =============================================================
    //  Replies
    // =============================================================
    match /replies/{replyId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
                    && request.resource.data.authorEmail == userEmail()
                    && request.resource.data.text is string
                    && request.resource.data.text.size() <= 500
                    && request.resource.data.text.size() >= 1;

      allow update: if isSignedIn()
                    && (resource.data.authorEmail == userEmail() || isAdmin());

      allow delete: if isSignedIn()
                    && (resource.data.authorEmail == userEmail() || isAdmin());
    }

    // =============================================================
    //  Comment cooldowns — only the user can read/write their own
    // =============================================================
    match /comment_cooldowns/{email} {
      allow read: if isSignedIn() && email == userEmail();
      allow write: if isSignedIn() && email == userEmail();
    }

    // =============================================================
    //  Banned users — anyone can read (to check if they're banned),
    //  only admins can write
    // =============================================================
    match /banned_users/{email} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // =============================================================
    //  Login blocks — system writes (via Admin SDK), users can read their own
    // =============================================================
    match /login_blocks/{deviceId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /login_attempts/{deviceId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // =============================================================
    //  User lists (favorites, watch later, etc.)
    // =============================================================
    match /user_lists/{email} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && email == userEmail();
    }

    // =============================================================
    //  Reading history
    // =============================================================
    match /reading_history/{email} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && email == userEmail();
    }

    // =============================================================
    //  Reports
    // =============================================================
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn()
                    && request.resource.data.reportedBy == userEmail();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // =============================================================
    //  Default: deny everything else
    // =============================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
