<?xml version="1.0" encoding="utf-8"?>
<!-- A compact "Continue Reading" card: small cover + title + chapter.
     Shown in a horizontal scroll at the top of the main screen.
     Tapping it opens the Reader at the last-read chapter. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_card"
    android:padding="10dp"
    android:layout_marginEnd="8dp"
    android:elevation="2dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <ImageView
        android:id="@+id/imgCover"
        android:layout_width="44dp"
        android:layout_height="60dp"
        android:scaleType="centerCrop"
        android:background="@color/surface"
        android:contentDescription="غلاف" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="10dp"
        android:minWidth="120dp"
        android:maxWidth="180dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📖 استمر بالقراءة"
            android:textColor="@color/primary"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end"
            android:layout_marginTop="2dp"
            tools:text="One Piece" />

        <TextView
            android:id="@+id/tvChapter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:singleLine="true"
            android:layout_marginTop="1dp"
            tools:text="الفصل 1188" />
    </LinearLayout>

</LinearLayout>
