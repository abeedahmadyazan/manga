<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <com.yazan.manga.ui.ZoomableImageView
        android:id="@+id/pageImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:adjustViewBounds="true"
        android:scaleType="fitCenter"
        android:background="@color/background_dark"
        android:contentDescription="صفحة" />

    <!-- Loading indicator (centered spinner) -->
    <ProgressBar
        android:id="@+id/pageProgress"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="center"
        android:visibility="gone"
        android:indeterminateTint="@color/primary" />

    <!-- Download progress text (e.g. "تحميل 45%") -->
    <TextView
        android:id="@+id/tvProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="50dp"
        android:text="جارٍ التحميل..."
        android:textColor="@color/primary"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- Horizontal progress bar showing download percentage -->
    <ProgressBar
        android:id="@+id/pageDownloadProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="200dp"
        android:layout_height="6dp"
        android:layout_gravity="center"
        android:layout_marginTop="70dp"
        android:max="100"
        android:progress="0"
        android:visibility="gone"
        android:progressTint="@color/primary" />

</FrameLayout>
