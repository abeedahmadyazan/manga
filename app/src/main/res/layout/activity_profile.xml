<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_media_previous"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/white"
                android:contentDescription="رجوع" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="حسابي"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center" />

            <View
                android:layout_width="40dp"
                android:layout_height="40dp" />
        </LinearLayout>

        <!-- Avatar -->
        <ImageView
            android:id="@+id/avatar"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@android:drawable/ic_menu_my_calendar"
            android:background="@color/surface"
            android:tint="@color/primary"
            android:padding="20dp"
            android:layout_marginBottom="16dp" />

        <!-- Username (visible when logged in) -->
        <TextView
            android:id="@+id/tvUsername"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <!-- Admin badge -->
        <TextView
            android:id="@+id/tvAdminBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👑 مشرف"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:background="@color/primary"
            android:paddingHorizontal="12dp" android:paddingVertical="4dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <!-- Email (visible when logged in) -->
        <TextView
            android:id="@+id/tvEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <!-- Device ID (visible when logged in) -->
        <TextView
            android:id="@+id/tvDeviceId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:layout_marginBottom="24dp"
            android:visibility="gone" />

        <!-- Email input (visible when logged out) -->
        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="أدخل إيميل Google"
            android:textColorHint="@color/text_secondary"
            android:textColor="@color/white"
            android:background="@drawable/bg_search_input"
            android:paddingHorizontal="16dp"
            android:textSize="15sp"
            android:inputType="textEmailAddress"
            android:singleLine="true"
            android:layout_marginBottom="12dp" />

        <!-- Login button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="تسجيل الدخول"
            android:textSize="15sp"
            app:cornerRadius="12dp" />

        <!-- Stats (visible when logged in) -->
        <LinearLayout
            android:id="@+id/statsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:visibility="gone"
            android:layout_marginTop="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@color/surface"
                android:padding="12dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:id="@+id/tvComments"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="تعليقات"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@color/surface"
                android:padding="12dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="مفضلة"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@color/surface"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="سجل"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Logout button (visible when logged in) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="تسجيل الخروج"
            android:textSize="15sp"
            android:layout_marginTop="32dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:textColor="@color/text_secondary"
            app:cornerRadius="12dp"
            android:visibility="gone" />

        <!-- Change username button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnChangeUsername"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="✏️ تغيير اسم المستخدم"
            android:textSize="14sp"
            android:layout_marginTop="12dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:textColor="@color/primary"
            app:strokeColor="@color/primary"
            app:cornerRadius="12dp"
            android:visibility="gone" />

        <!-- Admin panel button (admin only) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAdminPanel"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="👑 لوحة المشرف"
            android:textSize="14sp"
            android:layout_marginTop="12dp"
            app:cornerRadius="12dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
