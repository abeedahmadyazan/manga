<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:background="@color/background_dark"
    android:layoutDirection="rtl">

    <!-- ============ Top bar ============ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="36dp"
        android:paddingHorizontal="12dp"
        android:paddingBottom="10dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            android:contentDescription="رجوع"
            android:tint="@color/text_primary"
            tools:ignore="HardcodedText,UseAppTint" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="الملف الشخصي"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:ignore="HardcodedText" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- ============ Avatar ============ -->
            <FrameLayout
                android:layout_width="108dp"
                android:layout_height="108dp"
                android:layout_gravity="center">

                <ImageView
                    android:id="@+id/avatarImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_avatar_gradient"
                    android:visibility="gone"
                    android:contentDescription="الصورة الرمزية" />

                <TextView
                    android:id="@+id/avatarLetter"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_avatar_gradient"
                    android:gravity="center"
                    android:text="ز"
                    android:textColor="@color/white"
                    android:textSize="48sp"
                    android:textStyle="bold"
                    tools:ignore="HardcodedText" />

                <!-- Camera overlay button (bottom-end corner) — visible only when logged in -->
                

        <ImageButton
                    android:id="@+id/btnChangeAvatar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/bg_circle_button"
                    android:src="@drawable/ic_edit"
                    android:scaleType="center"
                    android:padding="8dp"
                    android:tint="@color/white"
                    android:contentDescription="تغيير الصورة"
                    android:visibility="gone"
                    tools:ignore="HardcodedText,UseAppTint" />

                <!-- Circular progress overlay — shown while the avatar is being saved -->
                <ProgressBar
                    android:id="@+id/avatarProgress"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:indeterminateTint="@color/white"
                    android:visibility="gone"
                    tools:ignore="UnusedAttribute" />
            </FrameLayout>

            <!-- Name + admin badge -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="14dp">

                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="زائر"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:id="@+id/tvAdminBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="3dp"
                    android:background="@drawable/bg_chapter_num"
                    android:text="مشرف"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:ignore="HardcodedText" />

                <!-- Pencil edit icon — opens the change-name dialog.
                     Replaces the full-width "تغيير الاسم" button. -->
                <ImageButton
                    android:id="@+id/btnEditName"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_edit"
                    android:tint="@color/primary"
                    android:scaleType="center"
                    android:padding="8dp"
                    android:visibility="gone"
                    android:contentDescription="تعديل الاسم"
                    tools:ignore="UseAppTint" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvUsername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="2dp"
                android:text=""
                android:textColor="@color/primary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="6dp"
                android:text=""
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:drawablePadding="6dp"
                android:drawableStart="@drawable/ic_email"
                android:drawableTint="@color/text_muted"
                tools:ignore="UseAppTint" />

            <!-- Account creation date -->
            <TextView
                android:id="@+id/tvCreatedAt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="4dp"
                android:text=""
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:visibility="gone"
                tools:ignore="HardcodedText" />

            <!-- Optional: birth date (only shown if set) -->
            <TextView
                android:id="@+id/tvBirthDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="4dp"
                android:text=""
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:visibility="gone"
                tools:ignore="HardcodedText" />

            <!-- Optional: country (only shown if set) -->
            <TextView
                android:id="@+id/tvCountry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="4dp"
                android:text=""
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:visibility="gone"
                tools:ignore="HardcodedText" />

            <!-- ============ Manga lists (pie chart + 4 cards) ============ -->
            <LinearLayout
                android:id="@+id/statsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="22dp"
                android:visibility="gone">

                <!-- Pie chart -->
                <com.yazan.manga.ui.PieChartView
                    android:id="@+id/pieChart"
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:layout_gravity="center" />

                <!-- 2x2 grid of list counts -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp"
                    android:weightSum="2">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="4dp"
                        app:cardBackgroundColor="@color/surface"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="1dp"
android:id="@+id/cardFavorites"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="14dp">

                            <TextView
                                android:id="@+id/tvStatFavorites"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#10b981"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                tools:ignore="HardcodedText" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="المفضلة"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"
                                tools:ignore="HardcodedText" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="4dp"
                        app:cardBackgroundColor="@color/surface"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="1dp"
android:id="@+id/cardWatchLater"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="14dp">

                            <TextView
                                android:id="@+id/tvStatWatchLater"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#8b5cf6"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                tools:ignore="HardcodedText" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="أتابع لاحقاً"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"
                                tools:ignore="HardcodedText" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp"
                    android:weightSum="2">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="4dp"
                        app:cardBackgroundColor="@color/surface"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="1dp"
android:id="@+id/cardWantToWatch"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="14dp">

                            <TextView
                                android:id="@+id/tvStatWantToWatch"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#f59e0b"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                tools:ignore="HardcodedText" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="أرغب بمتابعتها"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"
                                tools:ignore="HardcodedText" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="4dp"
                        app:cardBackgroundColor="@color/surface"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="1dp"
android:id="@+id/cardCompleted"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="14dp">

                            <TextView
                                android:id="@+id/tvStatCompleted"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#3b82f6"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                tools:ignore="HardcodedText" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="أنهيتها"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"
                                tools:ignore="HardcodedText" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            
            </LinearLayout>

            <!-- ============ Reading statistics ============ -->
            <LinearLayout
                android:id="@+id/readingStatsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:weightSum="3"
                android:visibility="gone">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card"
                    android:padding="12dp"
                    android:layout_marginEnd="4dp">
                    <TextView
                        android:id="@+id/tvStatTotalChapters"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/primary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        tools:ignore="HardcodedText" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="إجمالي الفصول"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        tools:ignore="HardcodedText" />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card"
                    android:padding="12dp"
                    android:layout_marginHorizontal="4dp">
                    <TextView
                        android:id="@+id/tvStatThisWeek"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/primary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        tools:ignore="HardcodedText" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="هذا الأسبوع"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        tools:ignore="HardcodedText" />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card"
                    android:padding="12dp"
                    android:layout_marginHorizontal="4dp">
                    <TextView
                        android:id="@+id/tvStatThisWeek"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/primary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        tools:ignore="HardcodedText" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="هذا الأسبوع"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        tools:ignore="HardcodedText" />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card"
                    android:padding="12dp"
                    android:layout_marginStart="4dp">
                    <TextView
                        android:id="@+id/tvStatToday"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/primary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        tools:ignore="HardcodedText" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="اليوم"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        tools:ignore="HardcodedText" />
                </LinearLayout>
            </LinearLayout>

<!-- ============ Change name (display name) ============ -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnChangeName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="تغيير الاسم"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_secondary_button"
                app:backgroundTint="@null"
                app:icon="@drawable/ic_edit"
                app:iconGravity="textStart"
                app:iconTint="@color/text_primary"
                android:visibility="gone"
                tools:ignore="HardcodedText" />

            <!-- ============ Change username (@handle) ============ -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnChangeUsername"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="تغيير اسم المستخدم"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_secondary_button"
                app:backgroundTint="@null"
                app:icon="@drawable/ic_edit"
                app:iconGravity="textStart"
                app:iconTint="@color/text_primary"
                android:visibility="gone"
                tools:ignore="HardcodedText" />

            <!-- ============ Birth date ============ -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditProfileInfo"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="🎂 تاريخ الميلاد"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_secondary_button"
                app:backgroundTint="@null"
                app:icon="@drawable/ic_edit"
                app:iconGravity="textStart"
                app:iconTint="@color/text_primary"
                android:visibility="gone"
                tools:ignore="HardcodedText" />

            <!-- ============ Country ============ -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditCountry"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="🌍 الدولة"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_secondary_button"
                app:backgroundTint="@null"
                app:icon="@drawable/ic_edit"
                app:iconGravity="textStart"
                app:iconTint="@color/text_primary"
                android:visibility="gone"
                tools:ignore="HardcodedText" />

            <!-- ============ Blocked users list ============ -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBlockedUsers"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="🚫 المحظورون"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_secondary_button"
                app:backgroundTint="@null"
                app:icon="@drawable/ic_ban"
                app:iconGravity="textStart"
                app:iconTint="@color/danger"
                android:visibility="gone"
                tools:ignore="HardcodedText" />

            <!-- ============ Admin panel ============ -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAdminPanel"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="لوحة المشرف"
                android:textColor="@color/warning"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_secondary_button"
                app:backgroundTint="@null"
                app:icon="@drawable/ic_admin"
                app:iconGravity="textStart"
                app:iconTint="@color/warning"
                android:visibility="gone"
                tools:ignore="HardcodedText" />

            
<!-- ============ Login button (Black Google styled) ============ -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="تسجيل الدخول عبر Google"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_google_button"
                    app:backgroundTint="@null"
                    app:icon="@drawable/ic_google"
                    app:iconGravity="textStart"
                    app:iconTint="@null"
                    tools:ignore="HardcodedText" />

                <!-- Spinning loader shown on top of the button while Google
                     Sign-In is in progress. Tinted white so it's visible on
                     the black button. -->
                <ProgressBar
                    android:id="@+id/loginProgress"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:indeterminateTint="@color/white"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- ============ Logout ============ -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:text="تسجيل الخروج"
                android:textColor="@color/danger"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_secondary_button"
                app:backgroundTint="@null"
                app:icon="@drawable/ic_logout"
                app:iconGravity="textStart"
                app:iconTint="@color/danger"
                android:visibility="gone"
                tools:ignore="HardcodedText" />

            <View
                android:layout_width="match_parent"
                android:layout_height="24dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
