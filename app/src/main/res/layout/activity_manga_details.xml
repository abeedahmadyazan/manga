<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/background_dark"
    android:layoutDirection="rtl">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ============ Hero cover with gradient + title overlay ============ -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/mangaCover"
                        android:layout_width="match_parent"
                        android:layout_height="280dp"
                        android:scaleType="centerCrop"
                        android:adjustViewBounds="true"
                        android:background="@color/surface"
                        android:contentDescription="غلاف المانجا"
                        tools:ignore="HardcodedText" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:layout_gravity="bottom"
                        android:background="@drawable/bg_gradient_overlay" />

                    <!-- Top action bar (overlay) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="14dp"
                        android:paddingTop="36dp"
                        android:paddingBottom="10dp">

                        <ImageButton
                            android:id="@+id/btnBack"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:background="@drawable/bg_circle_button"
                            android:src="@drawable/ic_back"
                            android:contentDescription="رجوع"
                            android:tint="@color/white"
                            tools:ignore="HardcodedText,UseAppTint" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <ImageButton
                            android:id="@+id/btnShare"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:background="@drawable/bg_circle_button"
                            android:src="@drawable/ic_share"
                            android:contentDescription="مشاركة"
                            android:tint="@color/white"
                            tools:ignore="HardcodedText,UseAppTint" />

                        <ImageButton
                            android:id="@+id/btnAddToList"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_circle_button"
                            android:src="@drawable/ic_bookmark"
                            android:contentDescription="إضافة لقائمة"
                            android:tint="@color/white"
                            tools:ignore="HardcodedText,UseAppTint" />

                        <ImageButton
                            android:id="@+id/btnMangaComments"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_circle_button"
                            android:src="@drawable/ic_comments"
                            android:contentDescription="تعليقات المانجا"
                            android:tint="@color/white"
                            tools:ignore="HardcodedText,UseAppTint" />
                    </LinearLayout>

                    <!-- Title overlay -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_gravity="bottom"
                        android:paddingHorizontal="20dp"
                        android:paddingBottom="16dp">

                        <TextView
                            android:id="@+id/mangaTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="One Piece"
                            android:textColor="@color/white"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:shadowColor="#000000"
                            android:shadowDx="0"
                            android:shadowDy="2"
                            android:shadowRadius="8"
                            tools:ignore="HardcodedText" />

                        <TextView
                            android:id="@+id/tvAltTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text=""
                            android:textColor="#ddffffff"
                            android:textSize="13sp" />
                    </LinearLayout>
                </FrameLayout>

                <!-- ============ Stat row (rating / chapters / status) ============ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="14dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="4dp"
                    android:weightSum="3">

                    <!-- Rating stat -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@color/surface"
                        android:padding="10dp"
                        android:layout_marginEnd="6dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="★"
                                android:textColor="@color/star"
                                android:textSize="16sp" />

                            <TextView
                                android:id="@+id/tvRating"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="0"
                                android:textColor="@color/text_primary"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                tools:ignore="HardcodedText" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="التقييم"
                            android:textColor="@color/text_muted"
                            android:textSize="11sp"
                            tools:ignore="HardcodedText" />
                    </LinearLayout>

                    <!-- Chapters stat -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@color/surface"
                        android:padding="10dp"
                        android:layout_marginEnd="6dp">

                        <TextView
                            android:id="@+id/tvChapters"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            tools:ignore="HardcodedText" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="فصل"
                            android:textColor="@color/text_muted"
                            android:textSize="11sp"
                            tools:ignore="HardcodedText" />
                    </LinearLayout>

                    <!-- Status stat -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@color/surface"
                        android:padding="10dp">

                        <TextView
                            android:id="@+id/tvStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="مستمرة"
                            android:textColor="@color/status_ongoing"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            tools:ignore="HardcodedText" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="الحالة"
                            android:textColor="@color/text_muted"
                            android:textSize="11sp"
                            tools:ignore="HardcodedText" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Author row (below stats) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="4dp">

                    <TextView
                        android:id="@+id/tvAuthor"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="المؤلف: —"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        tools:ignore="HardcodedText" />
                </LinearLayout>

                <!-- ============ Genres ============ -->
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/genresChipGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    app:chipSpacingHorizontal="6dp"
                    app:chipSpacingVertical="4dp"
                    app:singleLine="false" />

                <!-- ============ Description card ============ -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="14dp"
                    android:layout_marginVertical="6dp"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="1dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="القصة"
                            android:textColor="@color/primary"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            tools:ignore="HardcodedText" />

                        <TextView
                            android:id="@+id/tvDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text=""
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:lineSpacingExtra="3dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ============ Start reading button ============ -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRead"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginHorizontal="14dp"
                    android:layout_marginTop="12dp"
                    android:text="ابدأ القراءة"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_primary_button"
                    app:backgroundTint="@null"
                    app:icon="@drawable/ic_play"
                    app:iconGravity="textStart"
                    app:iconTint="@color/white"
                    tools:ignore="HardcodedText" />

                <!-- ============ Sources chip group ============ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="14dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="2dp"
                    android:visibility="gone"
                    android:id="@+id/sourcesContainer">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="المصادر المتاحة"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:layout_marginBottom="6dp"
                        tools:ignore="HardcodedText" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/sourcesChipGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:chipSpacingHorizontal="6dp"
                        app:chipSpacingVertical="4dp" />
                </LinearLayout>

                <!-- ============ Chapter list header ============ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="22dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="الفصول"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:id="@+id/tvChaptersHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 فصل"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        tools:ignore="HardcodedText" />

                    <!-- Sort toggle button (next to the chapter count) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSortChapters"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginStart="12dp"
                        android:minWidth="0dp"
                        android:paddingHorizontal="12dp"
                        android:text="الأحدث"
                        android:textColor="@color/primary"
                        android:textSize="12sp"
                        android:background="@drawable/bg_secondary_button"
                        app:backgroundTint="@null"
                        app:icon="@drawable/ic_history"
                        app:iconGravity="textStart"
                        app:iconTint="@color/primary"
                        tools:ignore="HardcodedText" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/chaptersRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:paddingBottom="24dp"
                    android:clipToPadding="false" />

                <ProgressBar
                    android:id="@+id/loadingIndicator"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:layout_marginVertical="20dp"
                    android:visibility="gone"
                    android:indeterminateTint="@color/primary" />

                <TextView
                    android:id="@+id/errorText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:padding="24dp"
                    android:gravity="center"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp"
                    android:visibility="gone" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
