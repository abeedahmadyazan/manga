<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/background_dark"
    android:layoutDirection="rtl">

    <!-- Vertical scroll reader — all pages in a RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/pagesRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background_dark"
        android:overScrollMode="never"
        android:scrollbars="vertical" />

    <ProgressBar
        android:id="@+id/loadingIndicator"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="120dp"
        android:visibility="gone"
        android:indeterminateTint="@color/primary" />

    <TextView
        android:id="@+id/errorText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="120dp"
        android:padding="24dp"
        android:gravity="center"
        android:textColor="@color/text_secondary"
        android:textSize="15sp"
        android:visibility="gone" />

    <!-- ============ Overlay top bar ============ -->
    <LinearLayout
        android:id="@+id/topBarOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_gradient_overlay"
        android:paddingTop="36dp"
        android:paddingBottom="10dp"
        android:paddingHorizontal="12dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_circle_button"
                android:src="@drawable/ic_back"
                android:contentDescription="رجوع"
                android:tint="@color/white"
                tools:ignore="HardcodedText,UseAppTint" />

            <TextView
                android:id="@+id/chapterTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="10dp"
                android:text="الفصل 1"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/pageCounter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:background="@drawable/bg_circle_button"
                android:text="0 / 0"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />

            <ImageButton
                android:id="@+id/btnChapterComments"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_circle_button"
                android:src="@drawable/ic_comments"
                android:contentDescription="تعليقات"
                android:tint="@color/white"
                tools:ignore="HardcodedText,UseAppTint" />
        </LinearLayout>
    </LinearLayout>

    <!-- ============ Bottom navigation bar ============ -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_gradient_overlay"
        android:paddingHorizontal="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="24dp"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/btnPrevPage"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_circle_button"
            android:src="@drawable/ic_back"
            android:contentDescription="الصفحة السابقة"
            android:tint="@color/white"
            tools:ignore="HardcodedText,UseAppTint" />

        <SeekBar
            android:id="@+id/pageSeekBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="8dp" />

        <!-- Zoom OUT (shrink) — opposite of zoom-in -->
        <ImageButton
            android:id="@+id/btnZoomOut"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="2dp"
            android:background="@drawable/bg_circle_button"
            android:src="@drawable/ic_zoom_out"
            android:contentDescription="تصغير"
            android:tint="@color/white"
            tools:ignore="HardcodedText,UseAppTint" />

        <!-- Zoom IN (enlarge) -->
        <ImageButton
            android:id="@+id/btnZoomIn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/bg_circle_button"
            android:src="@drawable/ic_zoom_in"
            android:contentDescription="تكبير"
            android:tint="@color/white"
            tools:ignore="HardcodedText,UseAppTint" />

        <ImageButton
            android:id="@+id/btnNextPage"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/bg_circle_button"
            android:src="@drawable/ic_back"
            android:rotation="180"
            android:contentDescription="الصفحة التالية"
            android:tint="@color/white"
            tools:ignore="HardcodedText,UseAppTint" />
    </LinearLayout>

</RelativeLayout>
