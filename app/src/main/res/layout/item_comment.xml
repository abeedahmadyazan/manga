<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    android:background="@drawable/bg_card"
    android:gravity="top">

    <TextView
        android:id="@+id/commentAvatar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_avatar"
        android:gravity="center"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/commentAvatarImage"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_avatar"
        android:visibility="gone"
        android:contentDescription="صورة المعلّق" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/commentAdminBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_admin_name_pill"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:layout_marginEnd="6dp"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/commentAuthor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/commentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/commentText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:lineSpacingExtra="3dp"
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <!-- Like button: transparent, turns blue when selected -->
            <LinearLayout
                android:id="@+id/btnLike"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="6dp"
                android:background="@drawable/bg_btn_transparent"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/imgLike"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_like_new"
                    android:contentDescription="إعجاب" />

                <TextView
                    android:id="@+id/tvLikeCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/color_like"
                    android:textSize="11sp"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <!-- Dislike button: transparent, turns red when selected -->
            <LinearLayout
                android:id="@+id/btnDislike"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="6dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_btn_transparent"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/imgDislike"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_dislike_new"
                    android:contentDescription="عدم إعجاب" />

                <TextView
                    android:id="@+id/tvDislikeCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/color_dislike"
                    android:textSize="11sp"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <!-- Reply button -->
            <LinearLayout
                android:id="@+id/btnReply"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="6dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_btn_transparent"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_reply_new"
                    android:contentDescription="رد" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="رد"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <!-- Edit button (owner only) -->
            <LinearLayout
                android:id="@+id/btnEdit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="6dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_btn_transparent"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_edit_new"
                    android:contentDescription="تعديل" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="تعديل"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <!-- Edited indicator -->
            <TextView
                android:id="@+id/tvEdited"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="(معدّل)"
                android:textColor="@color/text_muted"
                android:textSize="9sp"
                android:padding="4dp"
                android:layout_marginStart="4dp"
                android:visibility="gone" />

            <!-- Delete button — cleaner trash icon -->
            <ImageView
                android:id="@+id/btnDelete"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_delete_new"
                android:padding="4dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_btn_transparent"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="حذف"
                android:visibility="gone" />

            <!-- Report button -->
            <ImageView
                android:id="@+id/btnReport"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_report_new"
                android:padding="4dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_btn_transparent"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="إبلاغ"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
