<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    android:background="@drawable/bg_card"
    android:gravity="top">

    <TextView
        android:id="@+id/commentAvatar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_avatar"
        android:gravity="center"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:textStyle="bold" />

    <!-- Avatar image (shown when the commenter has a cloud-uploaded photo) -->
    <ImageView
        android:id="@+id/commentAvatarImage"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_avatar"
        android:visibility="gone"
        android:contentDescription="صورة المعلّق" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Admin name shown in a green pill so nobody can impersonate
                 an admin by just writing '(مشرف)' in their name. -->
            <TextView
                android:id="@+id/commentAdminBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_admin_name_pill"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:layout_marginEnd="6dp"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- For non-admins, the author name is a plain TextView. -->
            <TextView
                android:id="@+id/commentAuthor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/commentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/commentText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:lineSpacingExtra="3dp"
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/btnLike"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👍 0"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/btnDislike"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👎 0"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:padding="4dp"
                android:layout_marginStart="12dp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/btnReply"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💬 رد"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:padding="4dp"
                android:layout_marginStart="12dp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <!-- Edit button (only shown for the comment owner) -->
            <TextView
                android:id="@+id/btnEdit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✏️ تعديل"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:padding="4dp"
                android:layout_marginStart="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:visibility="gone" />

            <!-- "Edited" indicator (shown if editedAt != null) -->
            <TextView
                android:id="@+id/tvEdited"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="(معدّل)"
                android:textColor="@color/text_muted"
                android:textSize="9sp"
                android:padding="4dp"
                android:layout_marginStart="4dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btnDelete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🗑️"
                android:textSize="13sp"
                android:padding="4dp"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btnReport"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚩"
                android:textSize="13sp"
                android:padding="4dp"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
