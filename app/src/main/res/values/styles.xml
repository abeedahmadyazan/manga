<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="ShapeAppearance.MangaCard" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeAppearance.Circle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="Widget.MangaApp.TextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/primary</item>
        <item name="boxBackgroundColor">@color/surface</item>
    </style>

    <!-- Typography styles using Tajawal font -->
    <style name="TextAppearance.MangaApp.Headline" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:fontFamily">@font/tajawal</item>
        <item name="fontFamily">@font/tajawal</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.MangaApp.Title" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:fontFamily">@font/tajawal</item>
        <item name="fontFamily">@font/tajawal</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.MangaApp.Body" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:fontFamily">@font/tajawal</item>
        <item name="fontFamily">@font/tajawal</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.MangaApp.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:fontFamily">@font/tajawal</item>
        <item name="fontFamily">@font/tajawal</item>
        <item name="android:textColor">@color/text_muted</item>
    </style>

</resources>
